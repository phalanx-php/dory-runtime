{
    "name": "phalanx-php/dory-runtime",
    "description": "Native scripting environment for Phalanx with supervised execution, lazy module services, and fluent orchestration",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "scripting",
        "cli",
        "async",
        "phalanx",
        "swoole"
    ],
    "homepage": "https://github.com/phalanx-php/dory-runtime",
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "phalanx-php/aegis": "^0.6",
        "phalanx-php/archon": "^0.6",
        "phalanx-php/themis": "^0.6",
        "phalanx-php/iris": "^0.6",
        "phalanx-php/grammata": "^0.6",
        "phalanx-php/stoa": "^0.6",
        "phalanx-php/styx": "^0.6",
        "symfony/var-dumper": "^7.0"
    },
    "suggest": {
        "phalanx-php/hydra": "For worker process parallelism",
        "phalanx-php/dorybin": "For static binary compilation via SPC"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    },
    "bin": [
        "bin/dory"
    ],
    "archive": {
        "exclude": [
            "/.aimind",
            "/.aimind/**",
            "/.claude",
            "/.claude/**",
            "/.daemon8",
            "/.daemon8/**",
            "/.DS_Store",
            "/.github",
            "/.github/**",
            "/.idea",
            "/.idea/**",
            "/.php-cs-fixer.cache",
            "/.phpstan-cache",
            "/.phpstan-cache/**",
            "/.phpunit.result.cache",
            "/brand",
            "/brand/**",
            "/demos",
            "/demos/**",
            "/docs",
            "/docs/**",
            "/examples",
            "/examples/**",
            "/phpcs.xml",
            "/phpstan.neon",
            "/phpunit.xml",
            "/phpunit.xml.dist",
            "/rector.php",
            "/SPEC.md",
            "/tests",
            "/tests/**",
            "/tmp",
            "/tmp/**",
            "/tools",
            "/tools/**",
            "/vendor",
            "/vendor/**"
        ]
    },
    "scripts": {
        "test": "php -d memory_limit=512M vendor/bin/phpunit -c phpunit.xml"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\Dory\\": "src/"
        },
        "files": [
            "src/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Dory\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.6.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
