{
    "name": "phalanx-php/bia-runtime",
    "description": "Native scripting environment for the Phalanx v2 host/runtime handoff",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "scripting",
        "cli",
        "async",
        "phalanx",
        "swoole"
    ],
    "homepage": "https://github.com/phalanx-php/bia-runtime",
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "support": {
        "source": "https://github.com/phalanx-php/bia-runtime"
    },
    "require": {
        "php": "^8.4",
        "phalanx-php/phalanx": "^2.0@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    },
    "bin": [
        "bin/bia"
    ],
    "archive": {
        "exclude": [
            "/.aimind",
            "/.aimind/**",
            "/.claude",
            "/.claude/**",
            "/.daemon8",
            "/.daemon8/**",
            "/.DS_Store",
            "/.github",
            "/.github/**",
            "/.idea",
            "/.idea/**",
            "/.php-cs-fixer.cache",
            "/.phpstan-cache",
            "/.phpstan-cache/**",
            "/.phpunit.result.cache",
            "/brand",
            "/brand/**",
            "/demos",
            "/demos/**",
            "/docs",
            "/docs/**",
            "/examples",
            "/examples/**",
            "/phpcs.xml",
            "/phpstan.neon",
            "/phpunit.xml",
            "/phpunit.xml.dist",
            "/rector.php",
            "/SPEC.md",
            "/tests",
            "/tests/**",
            "/tmp",
            "/tmp/**",
            "/tools",
            "/tools/**",
            "/vendor",
            "/vendor/**"
        ]
    },
    "scripts": {
        "release:check": "php tools/release-composer-check.php",
        "release:composer": "php tools/release-composer.php --stdout",
        "test": "php -d memory_limit=512M vendor/bin/phpunit -c phpunit.xml"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\Bia\\": "src/"
        },
        "files": [
            "src/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Bia\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../phalanx",
            "options": {
                "symlink": true,
                "versions": {
                    "phalanx-php/phalanx": "2.0.x-dev"
                }
            }
        }
    ],
    "extra": {
        "branch-alias": {
            "dev-main": "2.0.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
