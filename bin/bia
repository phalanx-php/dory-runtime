#!/usr/bin/env php
<?php

declare(strict_types=1);

use Phalanx\Bia\Runtime\BiaCli;

$autoload = dirname(__DIR__) . '/vendor/autoload.php';

if (!is_file($autoload)) {
    fwrite(STDERR, "Bia runtime dependencies are not installed.\n");
    exit(126);
}

require $autoload;

try {
    if (function_exists('phalanx_host_facts')) {
        $payload = json_decode(phalanx_host_facts(), true, flags: JSON_THROW_ON_ERROR);

        if (!is_array($payload)) {
            fwrite(STDERR, "Fatal: invalid host facts payload.\n");
            exit(126);
        }

        exit(BiaCli::fromNativeFacts($payload)->run());
    }

    $argv = $argv ?? [];
    array_shift($argv);

    exit(BiaCli::fromArgv(array_values($argv))->run());
} catch (Throwable $error) {
    fwrite(STDERR, $error->getMessage() . "\n");
    exit(126);
}
