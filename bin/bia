#!/usr/bin/env php
<?php

declare(strict_types=1);

// Static binary mode: the binary is a raw PHP CLI with an embedded PHAR appended.
// PHP's PHAR loader finds the archive by scanning backwards from EOF for the
// __HALT_COMPILER() signature, so \Phar::running() returns non-empty when we are
// executing from that embedded PHAR.
if (extension_loaded('Phar') && \Phar::running() !== '') {
    $pharAutoload = 'phar://' . \Phar::running() . '/vendor/autoload.php';

    if (is_file($pharAutoload)) {
        require $pharAutoload;

        $projectConfig = \Phalanx\Bia\Runtime\BiaProjectConfig::discover(getcwd() ?: '.');

        $env = array_filter(
            $_ENV + $_SERVER,
            static fn(string $key): bool => !str_starts_with($key, 'HTTP_'),
            ARRAY_FILTER_USE_KEY,
        );

        $context = [
            ...$projectConfig->contextOverlay(),
            ...$env,
            'argv' => $argv ?? $_SERVER['argv'] ?? [],
        ];

        $providers = [
            new \Phalanx\Bia\Runtime\BiaServiceBundle(),
            new \Phalanx\HttpClient\Bundle(),
            new \Phalanx\Filesystem\FilesystemServiceBundle(),
            new \Phalanx\Network\NetworkServiceBundle(),
            new \Phalanx\WebSocket\Bundle(),
        ];

        exit(
            \Phalanx\Console\Facade::starting($context)
                ->providers(...$providers)
                ->commands(\Phalanx\Bia\Command\BiaCommandGroup::commands())
                ->withErrorRenderers(new \Phalanx\Bia\Console\ScriptFaultRenderer())
                ->default('run')
                ->run()
        );
    }
}

$autoload = dirname(__DIR__) . '/vendor/autoload_runtime.php';

if (!is_file($autoload)) {
    $autoload = dirname(__DIR__, 3) . '/vendor/autoload_runtime.php';
}

if (!is_file($autoload)) {
    $autoload = dirname(__DIR__, 3) . '/phalanx/vendor/autoload_runtime.php';
}

if (!is_file($autoload)) {
    $autoload = dirname(__DIR__, 4) . '/vendor/autoload_runtime.php';
}

if (!is_file($autoload)) {
    fwrite(STDERR, "Could not find autoload_runtime.php. Run 'composer install' first.\n");
    exit(1);
}

$loader = require dirname($autoload) . '/autoload.php';

$loader->addPsr4('Phalanx\\Bia\\', dirname(__DIR__) . '/src/');
$functionsFile = dirname(__DIR__) . '/src/functions.php';

if (is_file($functionsFile) && !function_exists('bia')) {
    require $functionsFile;
}

$projectConfig = \Phalanx\Bia\Runtime\BiaProjectConfig::discover(getcwd() ?: '.');

$context = $_SERVER;
if ($_ENV && !isset($context['PATH']) && !isset($context['Path'])) {
    $context += $_ENV;
}

$providers = [
    new \Phalanx\Bia\Runtime\BiaServiceBundle(),
    new \Phalanx\HttpClient\Bundle(),
    new \Phalanx\Filesystem\FilesystemServiceBundle(),
    new \Phalanx\Network\NetworkServiceBundle(),
    new \Phalanx\WebSocket\Bundle(),
];

exit(
    \Phalanx\Console\Facade::starting([
        ...$projectConfig->contextOverlay(),
        ...$context,
    ])
        ->providers(...$providers)
        ->commands(\Phalanx\Bia\Command\BiaCommandGroup::commands())
        ->withErrorRenderers(new \Phalanx\Bia\Console\ScriptFaultRenderer())
        ->default('run')
        ->run(array_slice($_SERVER['argv'] ?? [], 1))
);
