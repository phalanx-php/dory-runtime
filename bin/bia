#!/usr/bin/env php
<?php

declare(strict_types=1);

// Static binary mode: the binary is a raw PHP CLI with an embedded PHAR appended.
// PHP's PHAR loader finds the archive by scanning backwards from EOF for the
// __HALT_COMPILER() signature, so \Phar::running() returns non-empty when we are
// executing from that embedded PHAR.
if (extension_loaded('Phar') && \Phar::running() !== '') {
    $pharAutoload = 'phar://' . \Phar::running() . '/vendor/autoload.php';

    if (is_file($pharAutoload)) {
        require $pharAutoload;

        $projectConfig = \Phalanx\Bia\Runtime\BiaProjectConfig::discover(getcwd() ?: '.');

        $env = array_filter(
            $_ENV + $_SERVER,
            static fn(string $key): bool => !str_starts_with($key, 'HTTP_'),
            ARRAY_FILTER_USE_KEY,
        );

        $context = [
            ...$projectConfig->contextOverlay(),
            ...$env,
            'argv' => $argv ?? $_SERVER['argv'] ?? [],
        ];

        $providers = [
            new \Phalanx\Bia\Runtime\BiaServiceBundle(),
            new \Phalanx\HttpClient\HttpServiceBundle(),
            new \Phalanx\Filesystem\FilesystemServiceBundle(),
            new \Phalanx\Network\NetworkServiceBundle(),
            new \Phalanx\WebSocket\WsServiceBundle(),
        ];

        exit(
            \Phalanx\Console\Application\Console::starting($context)
                ->providers(...$providers)
                ->commands(\Phalanx\Bia\Command\BiaCommandGroup::commands())
                ->withErrorRenderers(new \Phalanx\Bia\Console\ScriptFaultRenderer())
                ->default('run')
                ->run()
        );
    }
}

$autoload = dirname(__DIR__) . '/vendor/autoload_runtime.php';

if (!is_file($autoload)) {
    $autoload = dirname(__DIR__, 3) . '/vendor/autoload_runtime.php';
}

if (!is_file($autoload)) {
    $autoload = dirname(__DIR__, 4) . '/vendor/autoload_runtime.php';
}

if (!is_file($autoload)) {
    fwrite(STDERR, "Could not find autoload_runtime.php. Run 'composer install' first.\n");
    exit(1);
}

require $autoload;

use Phalanx\Console\Application\Console;
use Phalanx\Network\NetworkServiceBundle;
use Phalanx\Bia\Command\BiaCommandGroup;
use Phalanx\Bia\Console\ScriptFaultRenderer;
use Phalanx\Bia\Runtime\BiaProjectConfig;
use Phalanx\Bia\Runtime\BiaServiceBundle;
use Phalanx\Filesystem\FilesystemServiceBundle;
use Phalanx\WebSocket\WsServiceBundle;
use Phalanx\HttpClient\HttpServiceBundle;

return static fn(array $context): \Closure => static function () use ($context): int {
    $projectConfig = BiaProjectConfig::discover(getcwd() ?: '.');

    $merged = [
        ...$projectConfig->contextOverlay(),
        ...$context,
    ];

    $providers = [
        new BiaServiceBundle(),
        new HttpServiceBundle(),
        new FilesystemServiceBundle(),
        new NetworkServiceBundle(),
        new WsServiceBundle(),
    ];

    return Console::starting($merged)
        ->providers(...$providers)
        ->commands(BiaCommandGroup::commands())
        ->withErrorRenderers(new ScriptFaultRenderer())
        ->default('run')
        ->run();
};
